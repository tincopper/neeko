# 忽略 .pi 下所有内容
*

# 保留 .gitignore
!.gitignore

# 保留 trellis agents
!agents/
!agents/trellis-*.md

# 保留 trellis extension
!extensions/
!extensions/guardrails.json
!extensions/guardrails.v0.json
!extensions/trellis/
!extensions/trellis/**

# 保留 trellis prompts
!prompts/
!prompts/trellis-*.md

# 保留 settings.json
!settings.json

# 保留 skills
!skills/
!skills/grill-me/
!skills/grill-me/**
!skills/trellis-*/
!skills/trellis-*/**
