# 忽略 .omp 下所有内容
*
!.gitignore

# 保留 trellis 相关 agents
!agents/
!agents/trellis-*.md

# 保留 trellis extension
!extensions/
!extensions/trellis/
!extensions/trellis/**

# 保留 trellis 命令
!commands/
!commands/trellis-*.md

# 保留 trellis skills 及 grill-me
!skills/
!skills/trellis-*/
!skills/trellis-*/**
!skills/grill-me/
!skills/grill-me/**
!skills/zoom-out/
!skills/zoom-out/**
!skills/tdd/
!skills/tdd/**
!skills/html-effectiveness/
!skills/html-effectiveness/**
!skills/code-review/
!skills/code-review/**
!skills/code-walkthrough/
!skills/code-walkthrough/**
!skills/prototype/
!skills/prototype/**


# 保留 settings.json
!settings.json
