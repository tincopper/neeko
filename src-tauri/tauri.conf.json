{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Neeko",
  "version": "1.0.3",
  "identifier": "com.neeko.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Neeko",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "decorations": false,
        "transparent": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "license": "Apache-2.0",
    "licenseFile": "LICENSE.rtf",
    "publisher": "汤圆（Tincopper）",
    "copyright": "Copyright © 2024 汤圆（Tincopper）. All rights reserved."
  }
}
