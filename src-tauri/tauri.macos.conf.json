{
  "$schema": "https://schema.tauri.app/config/2",
  "bundle": {
    "targets": ["dmg"],
    "macOS": {
      "minimumSystemVersion": "10.13",
      "dmg": {
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        }
      }
    }
  },
  "app": {
    "windows": [
      {
        "decorations": true,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "title": ""
      }
    ]
  }
}